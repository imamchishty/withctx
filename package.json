{
  "name": "withctx",
  "version": "1.4.0",
  "description": "Compiled context layer for AI agents — Claude compiles your project knowledge into a living wiki",
  "license": "MIT",
  "author": "Imam Chishty",
  "repository": {
    "type": "git",
    "url": "https://github.com/imamchishty/withctx"
  },
  "homepage": "https://github.com/imamchishty/withctx",
  "keywords": [
    "claude",
    "ai",
    "agents",
    "wiki",
    "context",
    "knowledge",
    "llm",
    "documentation",
    "jira",
    "confluence",
    "teams",
    "onboarding"
  ],
  "type": "module",
  "bin": {
    "ctx": "./dist/cli/index.js",
    "ctx-mcp": "./dist/mcp/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bdd": "cucumber-js",
    "test:smoke": "bash scripts/smoke-trust-pipeline.sh",
    "smoke:onprem": "npm run build && node scripts/smoke-onprem.mjs",
    "lint": "eslint src/",
    "clean": "rm -rf dist/",
    "prepublishOnly": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@octokit/rest": "^21.0.0",
    "chalk": "^5.4.0",
    "chromadb": "^1.9.2",
    "commander": "^13.1.0",
    "csv-parse": "^5.6.0",
    "fastify": "^5.2.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "openai": "^4.73.0",
    "ora": "^8.2.0",
    "pdf-parse": "^1.1.1",
    "undici": "^8.0.2",
    "xlsx": "^0.18.5",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@types/node": "^22.12.0",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
